{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-end.sh",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/prompt-submit.sh",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/tool-use.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/tool-complete.sh",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/tool-complete.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/agent-start.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/agent-stop.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/response-stop.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "${DEVSCOPE_URL}/api/events/hook?event=notification",
            "headers": {
              "x-api-key": "${DEVSCOPE_API_KEY}"
            },
            "allowedEnvVars": ["DEVSCOPE_URL", "DEVSCOPE_API_KEY"],
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact.sh",
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "${DEVSCOPE_URL}/api/events/hook?event=task.completed",
            "headers": {
              "x-api-key": "${DEVSCOPE_API_KEY}"
            },
            "allowedEnvVars": ["DEVSCOPE_URL", "DEVSCOPE_API_KEY"],
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "http",
            "url": "${DEVSCOPE_URL}/api/events/hook?event=permission.request",
            "headers": {
              "x-api-key": "${DEVSCOPE_API_KEY}"
            },
            "allowedEnvVars": ["DEVSCOPE_URL", "DEVSCOPE_API_KEY"],
            "async": true
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "${DEVSCOPE_URL}/api/events/hook?event=worktree.create",
            "headers": {
              "x-api-key": "${DEVSCOPE_API_KEY}"
            },
            "allowedEnvVars": ["DEVSCOPE_URL", "DEVSCOPE_API_KEY"],
            "async": true
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "${DEVSCOPE_URL}/api/events/hook?event=worktree.remove",
            "headers": {
              "x-api-key": "${DEVSCOPE_API_KEY}"
            },
            "allowedEnvVars": ["DEVSCOPE_URL", "DEVSCOPE_API_KEY"],
            "async": true
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "${DEVSCOPE_URL}/api/events/hook?event=config.change",
            "headers": {
              "x-api-key": "${DEVSCOPE_API_KEY}"
            },
            "allowedEnvVars": ["DEVSCOPE_URL", "DEVSCOPE_API_KEY"],
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-compact.sh",
            "async": true
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/elicitation.sh",
            "async": true
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/elicitation-result.sh",
            "async": true
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/instructions-loaded.sh",
            "async": true
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "${DEVSCOPE_URL}/api/events/hook?event=teammate.idle",
            "headers": {
              "x-api-key": "${DEVSCOPE_API_KEY}"
            },
            "allowedEnvVars": ["DEVSCOPE_URL", "DEVSCOPE_API_KEY"],
            "async": true
          }
        ]
      }
    ]
  }
}
